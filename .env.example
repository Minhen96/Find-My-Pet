# 🐾 Find-My-Pet Environment Variables Example
# Copy this file to .env and fill in your local values.

# Database Configuration
DB_HOST=localhost
DB_PORT=5435
DB_USER=petadmin
DB_PASSWORD=your_secure_password_here
DB_NAME=findmypet_db
# DB_SSL=false # Set to true for cloud databases like Supabase/Neon

# pgAdmin Configuration (Optional - for local DB management)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password_here

# JWT Authentication
# Generated via: openssl rand -base64 32
JWT_SECRET=your_jwt_access_secret_here
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 Storage (For Pet Images)
R2_ACCOUNT_ID=your_account_id_from_r2_page
R2_ACCESS_KEY_ID=your_access_key_from_token_screen
R2_SECRET_ACCESS_KEY=your_secret_key_from_token_screen
R2_BUCKET_NAME=find-my-pet-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
